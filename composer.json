{
    "name": "foundryframe/foundryframe-plugin",
    "description": "Foundry Frame LLC's WordPress Plugin",
    "type": "project",
    "autoload": {
        "psr-4": {
            "FoundryFrame\\Includes\\": "includes/",
            "FoundryFrame\\Config\\": "includes/config/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "3.0"
    }
}
